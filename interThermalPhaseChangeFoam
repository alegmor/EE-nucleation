<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>interThermalPhaseChangeFoam — Nucleate Boiling Case Setup</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap');

  :root {
    --bg: #fafbfc; --surface: #fff; --surface-alt: #f3f5f8;
    --border: #d4d9e3; --border-light: #e8ecf2;
    --blue: #1e5faa; --blue-bg: #e9f0fa;
    --red: #b53629; --red-bg: #fbeae8;
    --teal: #0e7e6f; --teal-bg: #e4f5f2;
    --amber: #9e6c0a; --amber-bg: #fef6e4;
    --violet: #6b4fa0; --violet-bg: #f0ecf7;
    --green: #2d7a4f; --green-bg: #e6f5ed;
    --slate: #4a5568; --slate-bg: #edf0f4;
    --text: #2d3340; --text-dim: #6b7585; --text-bright: #141820;
    --mono: 'IBM Plex Mono', monospace;
    --serif: 'Instrument Serif', Georgia, serif;
    --sans: 'DM Sans', system-ui, sans-serif;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:var(--sans); font-size:19px; line-height:1.65; padding:50px 32px 90px; }
  .container { max-width:1200px; margin:0 auto; }
  h1 { font-family:var(--serif); font-size:50px; font-weight:400; color:var(--text-bright); text-align:center; margin-bottom:4px; line-height:1.15; }
  h1 code { font-family:var(--mono); font-size:38px; color:var(--blue); font-weight:600; }
  .subtitle { text-align:center; color:var(--text-dim); font-size:17px; margin-bottom:12px; font-family:var(--mono); }
  .badges { display:flex; justify-content:center; gap:10px; flex-wrap:wrap; margin-bottom:52px; }
  .badge { font-family:var(--mono); font-size:13px; font-weight:600; padding:5px 14px; border-radius:5px; }
  .badge.b { background:var(--blue-bg); color:var(--blue); }
  .badge.r { background:var(--red-bg); color:var(--red); }
  .badge.t { background:var(--teal-bg); color:var(--teal); }
  .badge.a { background:var(--amber-bg); color:var(--amber); }

  .flow { display:flex; flex-direction:column; align-items:center; gap:0; }
  .connector { width:2.5px; height:36px; position:relative; background:linear-gradient(to bottom,var(--border),var(--blue)); }
  .connector::after { content:'▾'; position:absolute; bottom:-13px; left:50%; transform:translateX(-50%); font-size:15px; color:var(--blue); }
  .connector.r { background:linear-gradient(to bottom,var(--border),var(--red)); } .connector.r::after { color:var(--red); }
  .connector.t { background:linear-gradient(to bottom,var(--border),var(--teal)); } .connector.t::after { color:var(--teal); }
  .connector.a { background:linear-gradient(to bottom,var(--border),var(--amber)); } .connector.a::after { color:var(--amber); }
  .connector.v { background:linear-gradient(to bottom,var(--border),var(--violet)); } .connector.v::after { color:var(--violet); }
  .connector.g { background:linear-gradient(to bottom,var(--border),var(--green)); } .connector.g::after { color:var(--green); }
  .connector.s { background:linear-gradient(to bottom,var(--border),var(--slate)); } .connector.s::after { color:var(--slate); }

  .node { background:var(--surface); border:1.5px solid var(--border); border-radius:12px; padding:30px 34px; max-width:1100px; width:100%; position:relative; transition:border-color .25s,box-shadow .25s; }
  .node:hover { box-shadow:0 5px 28px rgba(0,0,0,.05); }
  .node.start { background:linear-gradient(135deg,var(--blue-bg),#dce6f5); border-color:var(--blue); }
  .node.result { background:linear-gradient(135deg,var(--green-bg),#d4eddf); border-color:var(--green); text-align:center; }
  .node.bb { border-color:var(--blue); } .node.rb { border-color:var(--red); } .node.tb { border-color:var(--teal); }
  .node.ab { border-color:var(--amber); } .node.vb { border-color:var(--violet); } .node.gb { border-color:var(--green); }
  .node.sb { border-color:var(--slate); background:var(--slate-bg); }

  .node-label { position:absolute; top:-12px; left:20px; background:var(--bg); padding:0 10px; font-family:var(--mono); font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:1.8px; }
  .node-label.blue{color:var(--blue);} .node-label.red{color:var(--red);} .node-label.teal{color:var(--teal);}
  .node-label.amber{color:var(--amber);} .node-label.violet{color:var(--violet);} .node-label.green{color:var(--green);} .node-label.slate{color:var(--slate);}

  .node-title { font-family:var(--serif); font-size:28px; color:var(--text-bright); margin-bottom:10px; line-height:1.3; }
  .detail { color:var(--text-dim); font-size:17px; margin-top:10px; line-height:1.75; }
  .detail strong { color:var(--text); font-weight:600; }
  .detail code { font-family:var(--mono); font-size:15px; background:var(--surface-alt); padding:1px 5px; border-radius:3px; }
  .tikz-figure { display:flex; justify-content:center; margin:20px 0 12px; overflow-x:auto; }
  .tikz-figure img { max-width:100%; height:auto; border-radius:6px; }

  .prop-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin:14px 0; }
  .prop-card { border-radius:8px; padding:16px 18px; font-size:16px; border:1px solid var(--border-light); }
  .prop-card .label { font-family:var(--mono); font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:.9px; margin-bottom:6px; }

  /* Collapsible fluid selector */
  .fluid-section { margin:18px 0; }
  .fluid-tabs { display:flex; gap:0; border-bottom:2px solid var(--border-light); margin-bottom:0; }
  .fluid-tab {
    padding:10px 22px; font-family:var(--mono); font-size:14px; font-weight:600;
    cursor:pointer; border:1.5px solid transparent; border-bottom:none;
    border-radius:8px 8px 0 0; color:var(--text-dim); background:var(--surface-alt);
    transition:all .2s;
  }
  .fluid-tab:hover { color:var(--blue); background:var(--blue-bg); }
  .fluid-tab.active { color:var(--blue); background:var(--surface); border-color:var(--border-light); border-bottom:2px solid var(--surface); margin-bottom:-2px; }
  .fluid-panel {
    display:none; border:1.5px solid var(--border-light); border-top:none;
    border-radius:0 0 8px 8px; padding:18px 22px; background:var(--surface);
  }
  .fluid-panel.active { display:block; }
  .fluid-panel table { width:100%; border-collapse:collapse; font-size:15px; }
  .fluid-panel th { text-align:left; padding:6px 10px; font-family:var(--mono); font-size:12px; color:var(--text-dim); text-transform:uppercase; letter-spacing:.6px; border-bottom:1px solid var(--border-light); }
  .fluid-panel td { padding:6px 10px; border-bottom:1px solid var(--border-light); }
  .fluid-panel td:first-child { font-weight:600; color:var(--text-bright); }

  .bc-table { width:100%; border-collapse:collapse; margin:14px 0; font-size:15px; font-family:var(--mono); }
  .bc-table th { background:var(--surface-alt); border:1px solid var(--border-light); padding:10px 12px; text-align:left; font-weight:700; font-size:13px; text-transform:uppercase; letter-spacing:.8px; color:var(--text-dim); }
  .bc-table td { border:1px solid var(--border-light); padding:9px 12px; color:var(--text); font-size:14.5px; line-height:1.5; }
  .bc-table tr:hover td { background:var(--blue-bg); }

  .file-table { width:100%; border-collapse:collapse; margin:12px 0; font-size:16px; }
  .file-table th { background:var(--surface-alt); border:1px solid var(--border-light); padding:9px 12px; text-align:left; font-weight:700; font-size:13px; text-transform:uppercase; letter-spacing:.8px; color:var(--text-dim); font-family:var(--mono); }
  .file-table td { border:1px solid var(--border-light); padding:8px 12px; color:var(--text); font-size:15px; }
  .file-table td:first-child { font-family:var(--mono); font-weight:600; color:var(--blue); font-size:14px; }
  .file-table td:nth-child(2) { font-family:var(--mono); font-size:13px; color:var(--text-dim); }
  .file-table tr:hover td { background:var(--blue-bg); }

  .flow > * { opacity:0; transform:translateY(10px); animation:fadeUp .4s ease forwards; }
  @keyframes fadeUp { to { opacity:1; transform:translateY(0); } }
.flow > *:nth-child(1) { animation-delay: 0.00s; }
.flow > *:nth-child(2) { animation-delay: 0.04s; }
.flow > *:nth-child(3) { animation-delay: 0.08s; }
.flow > *:nth-child(4) { animation-delay: 0.12s; }
.flow > *:nth-child(5) { animation-delay: 0.16s; }
.flow > *:nth-child(6) { animation-delay: 0.20s; }
.flow > *:nth-child(7) { animation-delay: 0.24s; }
.flow > *:nth-child(8) { animation-delay: 0.28s; }
.flow > *:nth-child(9) { animation-delay: 0.32s; }
.flow > *:nth-child(10) { animation-delay: 0.36s; }
.flow > *:nth-child(11) { animation-delay: 0.40s; }
.flow > *:nth-child(12) { animation-delay: 0.44s; }
.flow > *:nth-child(13) { animation-delay: 0.48s; }
.flow > *:nth-child(14) { animation-delay: 0.52s; }
.flow > *:nth-child(15) { animation-delay: 0.56s; }
.flow > *:nth-child(16) { animation-delay: 0.60s; }
.flow > *:nth-child(17) { animation-delay: 0.64s; }
.flow > *:nth-child(18) { animation-delay: 0.68s; }
.flow > *:nth-child(19) { animation-delay: 0.72s; }
.flow > *:nth-child(20) { animation-delay: 0.76s; }
.flow > *:nth-child(21) { animation-delay: 0.80s; }
.flow > *:nth-child(22) { animation-delay: 0.84s; }
.flow > *:nth-child(23) { animation-delay: 0.88s; }
.flow > *:nth-child(24) { animation-delay: 0.92s; }
.flow > *:nth-child(25) { animation-delay: 0.96s; }
.flow > *:nth-child(26) { animation-delay: 1.00s; }
.flow > *:nth-child(27) { animation-delay: 1.04s; }
.flow > *:nth-child(28) { animation-delay: 1.08s; }
.flow > *:nth-child(29) { animation-delay: 1.12s; }
.flow > *:nth-child(30) { animation-delay: 1.16s; }

  @media (max-width:800px) { body{padding:24px 12px 50px;font-size:16px;} h1{font-size:32px;} h1 code{font-size:24px;} .node{padding:20px 16px;} .node-title{font-size:22px;} .prop-grid{grid-template-columns:1fr;} }
</style>
</head>
<body>
<div class="container">
  <h1>Nucleate Boiling Case Setup<br><code>interThermalPhaseChangeFoam</code></h1>
  <p class="subtitle">Single-bubble nucleation on a superheated wall · Water/Steam at 1 atm</p>
  <div class="badges">
    <span class="badge b">2D · 25 mm × 25 mm</span>
    <span class="badge r">ΔT_wall = +2 K</span>
    <span class="badge t">InterfaceEquilibrium_SplitDilatation</span>
    <span class="badge a">Brackbill surface tension</span>
  </div>
  <div class="flow">

    <!-- NODE 0: DOMAIN -->
    <div class="node start">
      <span class="node-label blue">Pre-processing · Step 0</span>
      <div class="node-title">Domain & Mesh Generation</div>
      <div class="detail">
        A 2D planar domain of <strong>25 mm × 25 mm</strong> with single-cell depth Δz = 104 μm.
        Multi-block structured mesh (9 blocks, 3 horizontal bands).
        File: <code>constant/polyMesh/blockMeshDict</code>
      </div>
      <div class="tikz-figure"><img src="data:image/png;base64," alt="Domain and mesh diagram"></div>
    </div>

    <div class="connector r"></div>

    <!-- NODE 1: BUBBLE SEEDING -->
    <div class="node rb">
      <span class="node-label red">Pre-processing · Step 1</span>
      <div class="node-title">Artificial Bubble Seeding</div>
      <div class="detail">
        A vapour embryo (hemisphere, <em>R</em> = 1 mm) is placed on the heated wall
        <strong>before</strong> the simulation starts. Two utilities run in sequence:
      </div>
      <div class="tikz-figure"><img src="data:image/png;base64," alt="Bubble seeding process"></div>
    </div>

    <div class="connector a"></div>

    <!-- NODE 2: MATERIAL PROPERTIES with fluid tabs -->
    <div class="node ab">
      <span class="node-label amber">Pre-processing · Step 2</span>
      <div class="node-title">Material Properties & Model Selection</div>
      <div class="detail" style="margin-bottom:12px;">
        File: <code>constant/transportProperties</code> — Select a working fluid to view its properties:
      </div>

      <!-- Fluid tab selector -->
      <div class="fluid-section">
        <div class="fluid-tabs">
          <div class="fluid-tab active" onclick="showFluid('water',this)">Water</div>
          <div class="fluid-tab" onclick="showFluid('ethanol',this)">Ethanol</div>
          <div class="fluid-tab" onclick="showFluid('fc72',this)">FC-72</div>
          <div class="fluid-tab" onclick="showFluid('novec',this)">Novec-649</div>
        </div>
        <!-- Water -->
        <div class="fluid-panel active" id="fluid-water">
          <table>
            <tr><th>Property (at p = 101.3 kPa)</th><th>Liquid</th><th>Vapour</th></tr>
            <tr><td>T<sub>sat</sub></td><td colspan="2" style="text-align:center;">100 °C (373.15 K)</td></tr>
            <tr><td>ρ (kg/m³)</td><td>959</td><td>0.597</td></tr>
            <tr><td>μ (Pa·s)</td><td>2.80 × 10⁻⁴</td><td>1.22 × 10⁻⁵</td></tr>
            <tr><td>k (W/(m·K))</td><td>0.68</td><td>0.025</td></tr>
            <tr><td>c<sub>p</sub> (J/(kg·K))</td><td>4216</td><td>2080</td></tr>
            <tr><td>h<sub>lv</sub> (kJ/kg)</td><td colspan="2" style="text-align:center;">2251</td></tr>
            <tr><td>σ (N/m)</td><td colspan="2" style="text-align:center;">0.0589</td></tr>
          </table>
          <div style="margin-top:10px;font-size:14px;color:var(--teal);font-weight:600;">✓ Currently used in this case</div>
        </div>
        <!-- Ethanol -->
        <div class="fluid-panel" id="fluid-ethanol">
          <table>
            <tr><th>Property (at p = 101.3 kPa)</th><th>Liquid</th><th>Vapour</th></tr>
            <tr><td>T<sub>sat</sub></td><td colspan="2" style="text-align:center;">78.3 °C (351.45 K)</td></tr>
            <tr><td>ρ (kg/m³)</td><td>757</td><td>1.43</td></tr>
            <tr><td>h<sub>lv</sub> (kJ/kg)</td><td colspan="2" style="text-align:center;">963</td></tr>
            <tr><td>k<sub>l</sub> (W/(m·K))</td><td colspan="2" style="text-align:center;">0.169</td></tr>
            <tr><td>σ (N/m)</td><td colspan="2" style="text-align:center;">0.0177</td></tr>
          </table>
        </div>
        <!-- FC-72 -->
        <div class="fluid-panel" id="fluid-fc72">
          <table>
            <tr><th>Property (at p = 101.3 kPa)</th><th>Liquid</th><th>Vapour</th></tr>
            <tr><td>T<sub>sat</sub></td><td colspan="2" style="text-align:center;">56.4 °C (329.55 K)</td></tr>
            <tr><td>ρ (kg/m³)</td><td>1602</td><td>13.24</td></tr>
            <tr><td>h<sub>lv</sub> (kJ/kg)</td><td colspan="2" style="text-align:center;">94.9</td></tr>
            <tr><td>k<sub>l</sub> (W/(m·K))</td><td colspan="2" style="text-align:center;">0.055</td></tr>
            <tr><td>σ (N/m)</td><td colspan="2" style="text-align:center;">0.0081</td></tr>
          </table>
        </div>
        <!-- Novec-649 -->
        <div class="fluid-panel" id="fluid-novec">
          <table>
            <tr><th>Property (at p = 101.3 kPa)</th><th>Liquid</th><th>Vapour</th></tr>
            <tr><td>T<sub>sat</sub></td><td colspan="2" style="text-align:center;">49.0 °C (322.15 K)</td></tr>
            <tr><td>ρ (kg/m³)</td><td>1513</td><td>13.42</td></tr>
            <tr><td>h<sub>lv</sub> (kJ/kg)</td><td colspan="2" style="text-align:center;">88.0</td></tr>
            <tr><td>k<sub>l</sub> (W/(m·K))</td><td colspan="2" style="text-align:center;">0.059</td></tr>
            <tr><td>σ (N/m)</td><td colspan="2" style="text-align:center;">0.0108</td></tr>
          </table>
        </div>
      </div>

      <!-- Model cards -->
      <div class="prop-grid" style="margin-top:18px;">
        <div class="prop-card" style="background:var(--teal-bg); border-color:rgba(14,126,111,0.15);">
          <div class="label" style="color:var(--teal);">Phase-change model</div>
          <strong>InterfaceEquilibrium_SplitDilatation</strong><br>
          h<sub>lv</sub> = 2.251×10⁶ J/kg · T<sub>sat</sub> = 373.15 K<br>
          CondThresh = 0.5 · EvapThresh = 0.1 · RelaxFac = 1.0
        </div>
        <div class="prop-card" style="background:var(--amber-bg); border-color:rgba(158,108,10,0.12);">
          <div class="label" style="color:var(--amber);">Surface tension</div>
          <strong>Brackbill</strong> (CSF) · σ = 0.0589 N/m<br>
          f<sub>σ</sub> = σ κ ∇α₁<br>
          Contact angle at wall: θ₀ = 35°
        </div>
      </div>
    </div>

    <div class="connector"></div>

    <!-- NODE 3: BOUNDARY CONDITIONS (renamed) -->
    <div class="node bb">
      <span class="node-label blue">Pre-processing · Step 3</span>
      <div class="node-title">Boundary Conditions</div>
      <div class="detail" style="margin-bottom:12px;">
        The driving force for nucleation is the <strong>fixed wall superheat</strong> on the bottom patch.
        Each field file in <code>0/</code>.
      </div>
      <table class="bc-table">
        <tr><th>Patch</th><th>α₁ (alpha1)</th><th>T</th><th>U</th><th>p_rgh</th></tr>
        <tr>
          <td style="color:var(--red);font-weight:700;">bottom<br><span style="font-size:12px;color:var(--text-dim);">heated wall</span></td>
          <td>constantAlpha-<br>ContactAngle<br>θ₀ = 35°</td>
          <td><strong>fixedValue</strong><br>T = 375.15 K<br>(T<sub>sat</sub> + 2 K)</td>
          <td>fixedValue<br>u = (0,0,0)<br>no-slip</td>
          <td>fixedFlux-<br>Pressure</td>
        </tr>
        <tr>
          <td style="color:var(--teal);font-weight:700;">outlet<br><span style="font-size:12px;color:var(--text-dim);">top</span></td>
          <td>inletOutlet<br>inletValue = 1</td>
          <td>inletOutlet<br>inletValue = T<sub>sat</sub></td>
          <td>pressureInlet-<br>OutletVelocity</td>
          <td><strong>totalPressure</strong><br>p₀ = 0</td>
        </tr>
        <tr>
          <td style="color:var(--slate);font-weight:700;">walls<br><span style="font-size:12px;color:var(--text-dim);">left & right</span></td>
          <td>zeroGradient</td>
          <td>zeroGradient</td>
          <td>fixedValue<br>u = (0,0,0)</td>
          <td>fixedFlux-<br>Pressure</td>
        </tr>
        <tr>
          <td style="color:var(--text-dim);font-weight:700;">frontAndBack</td>
          <td colspan="4" style="text-align:center;color:var(--text-dim);"><strong>empty</strong> — enforces 2D simulation</td>
        </tr>
      </table>
      <div class="detail">
        <strong>Commented alternative in <code>0/T</code>:</strong> A <code>groovyBC</code> (swak4Foam) option would impose
        q″ = 20 kW/m² via ∇T = q″/(α₁·0.68 + (1−α₁)·0.025). Currently <strong>not active</strong>.
      </div>
    </div>

    <div class="connector v"></div>

    <!-- NODE 4: SOLVER -->
    <div class="node vb">
      <span class="node-label violet">Runtime · Solver Algorithm</span>
      <div class="node-title">Time-stepping Loop (PIMPLE)</div>
      <div class="tikz-figure"><img src="data:image/png;base64," alt="PIMPLE solver algorithm"></div>
    </div>

    <div class="connector t"></div>

    <!-- NODE 5: PHYSICS -->
    <div class="node tb">
      <span class="node-label teal">Physics</span>
      <div class="node-title">How the Bubble Grows — Energy Pathway</div>
      <div class="tikz-figure"><img src="data:image/png;base64," alt="Physics energy pathway"></div>
    </div>

    <div class="connector s"></div>

    <!-- NODE 6: FILE MAP -->
    <div class="node sb">
      <span class="node-label slate">Reference</span>
      <div class="node-title">File → Equation Map</div>
      <table class="file-table">
        <tr><th>File</th><th>Location</th><th>Role</th></tr>
        <tr><td>blockMeshDict</td><td>constant/polyMesh/</td><td>Domain geometry, 9-block structured mesh</td></tr>
        <tr><td>topoSetDict</td><td>system/</td><td>Hemisphere cell set <code>c0</code> for bubble seed</td></tr>
        <tr><td>setFieldsDict</td><td>system/</td><td>Sets α₁ = 0, T = T<sub>sat</sub> inside seed</td></tr>
        <tr><td>transportProperties</td><td>constant/</td><td>Phase props, h<sub>lv</sub>, T<sub>sat</sub>, thresholds, σ, models</td></tr>
        <tr><td>alpha1</td><td>0/</td><td>Phase fraction BCs (contact angle at wall)</td></tr>
        <tr><td>T</td><td>0/</td><td>Temperature BCs (T<sub>wall</sub> = T<sub>sat</sub> + 2 K)</td></tr>
        <tr><td>U</td><td>0/</td><td>Velocity BCs (no-slip walls)</td></tr>
        <tr><td>p_rgh</td><td>0/</td><td>Pressure BCs (totalPressure outlet)</td></tr>
        <tr><td>H</td><td>0/</td><td>Enthalpy field (zeroGradient, solver-internal)</td></tr>
        <tr><td>InterfaceField</td><td>0/</td><td>Interface marker (zeroGradient, diagnostic)</td></tr>
        <tr><td>alphaEqn.H</td><td>solver source</td><td>VOF advection — Eq. 6</td></tr>
        <tr><td>UEqn.H</td><td>solver source</td><td>Momentum — Eq. 3</td></tr>
        <tr><td>pEqn.H</td><td>solver source</td><td>Pressure Poisson — Eq. 4 (∇·u = v̇<sub>pc</sub>)</td></tr>
        <tr><td>TEqn.H</td><td>solver source</td><td>Energy transport — Eq. 5 (q̇<sub>pc</sub> sink)</td></tr>
        <tr><td>InterfaceEquilibrium<br>_SplitDilatation.C</td><td>phaseChangeModels/</td><td>Computes q̇<sub>pc</sub>; splits v̇<sub>pc</sub> to liq./vap. sides</td></tr>
        <tr><td>Brackbill.C</td><td>surfaceTensionModels/</td><td>CSF surface tension f<sub>σ</sub> = σκ∇α₁</td></tr>
      </table>
    </div>

    <div class="connector g"></div>

    <!-- NODE 7: RESULT -->
    <div class="node result">
      <span class="node-label green">Output</span>
      <div class="node-title" style="color:var(--green);">Resolved Single-Bubble Nucleation</div>
      <div class="detail" style="text-align:left;">
        The simulation resolves the <strong>full lifecycle</strong> of a single nucleating bubble:
        inception from the artificial seed, growth driven by wall superheat,
        shape evolution governed by surface tension and buoyancy, and departure
        when buoyancy overcomes the contact-line adhesion force.
        No empirical correlations for N<sub>a</sub>, d<sub>w</sub>, or f are required —
        these emerge from the governing equations.
      </div>
    </div>

  </div>
</div>

<script>
function showFluid(id, tab) {
  document.querySelectorAll('.fluid-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.fluid-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('fluid-' + id).classList.add('active');
  tab.classList.add('active');
}
</script>
